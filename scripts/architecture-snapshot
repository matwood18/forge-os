  lib/demo/authorization/types.ts \
  lib/demo/authorization/authorization-decision-inspector-builder.ts \
  lib/demo/action/types.ts \
  lib/demo/action/action-inspector-builder.ts \
  app/forge-demo/components/execution-timeline.tsx \
  app/forge-demo/components/pass-execution-inspector.tsx \
  app/forge-demo/components/reflection-inspector.tsx \
  app/forge-demo/components/recommendation-inspector.tsx \
  app/forge-demo/components/authorization-decision-inspector.tsx \
  app/forge-demo/components/action-inspector.tsx

