# scripts/architecture-snapshot
#!/usr/bin/env bash

set -euo pipefail

print_section() {
  echo
  echo "$1"
  echo "----------------------------------------"
}

print_existing() {
  for path in "$@"; do
    if [ -e "$path" ]; then
      echo "✓ $path"
    else
      echo "✗ $path"
    fi
  done
}

echo "Forge OS Architecture Snapshot"
echo "========================================"

print_section "Commit"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"

print_section "Git Status"
git status --short

print_section "Core Cognitive Pipeline"
print_existing \
  lib/kernel/cognitive-pipeline/passes/reasoning-pass.ts \
  lib/kernel/cognitive-pipeline/passes/relationship-pass.ts \
  lib/kernel/cognitive-pipeline/passes/memory-pass.ts \
  lib/kernel/cognitive-pipeline/passes/curiosity-pass.ts \
  lib/kernel/cognitive-pipeline/passes/planning-pass.ts

print_section "Instrumentation"
