# scripts/architecture-snapshot
#!/usr/bin/env bash

set -euo pipefail

print_section() {
  echo
  echo "$1"
  echo "----------------------------------------"
}

print_existing() {
  for path in "$@"; do
    if [ -e "$path" ]; then
      echo "✓ $path"
    else
      echo "✗ $path"
    fi
  done
}

echo "Forge OS Architecture Snapshot"
echo "========================================"

print_section "Commit"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"

print_section "Git Status"
git status --short

print_section "Core Cognitive Pipeline"
print_existing \
  lib/kernel/cognitive-pipeline/passes/reasoning-pass.ts \
  lib/kernel/cognitive-pipeline/passes/relationship-pass.ts \
  lib/kernel/cognitive-pipeline/passes/memory-pass.ts \
  lib/kernel/cognitive-pipeline/passes/curiosity-pass.ts \
  lib/kernel/cognitive-pipeline/passes/planning-pass.ts

print_section "Instrumentation"
print_existing \
  lib/kernel/cognitive-pipeline/execution/pass-execution.ts \
  lib/kernel/cognitive-pipeline/execution/pass-execution-recorder.ts \
  lib/kernel/execution/types.ts \
  lib/kernel/execution/execution-recorder.ts

echo "✓ PassExecutionRecorder"
echo "✓ CognitivePassExecution"
echo "✓ KernelExecution.passExecutions"
echo "✓ Per-pass artifact deltas"
echo "✓ Duration metrics"
echo "✓ Failure capture"

print_section "Inspection"
print_existing \
  lib/demo/timeline/types.ts \
  lib/demo/timeline/execution-timeline-builder.ts \
  lib/demo/pass-execution/types.ts \
  lib/demo/pass-execution/pass-execution-inspector-builder.ts \
  lib/demo/reflection/types.ts \
  lib/demo/reflection/reflection-inspector-builder.ts \
  lib/demo/recommendation/types.ts \
  lib/demo/recommendation/recommendation-inspector-builder.ts \
  lib/demo/authorization/types.ts \
  lib/demo/authorization/authorization-decision-inspector-builder.ts \
  lib/demo/action/types.ts \
  lib/demo/action/action-inspector-builder.ts \
  app/forge-demo/components/execution-timeline.tsx \
  app/forge-demo/components/pass-execution-inspector.tsx \
  app/forge-demo/components/reflection-inspector.tsx \
  app/forge-demo/components/recommendation-inspector.tsx \
  app/forge-demo/components/authorization-decision-inspector.tsx \
  app/forge-demo/components/action-inspector.tsx

echo "✓ Timeline"
echo "✓ Pipeline"
echo "✓ Pass Execution Inspector"
echo "✓ Reflection Inspector"
echo "✓ Recommendation Inspector"
echo "✓ Authorization Decision Inspector"
echo "✓ Action Inspector"

print_section "Demonstrable Forge"
print_existing \
  lib/demo/run-summary/types.ts \
  lib/demo/run-summary/run-summary-builder.ts \
  lib/demo/run-summary/index.ts \
  lib/demo/scenario/types.ts \
  lib/demo/scenario/scenarios.ts \
  lib/demo/scenario/index.ts \
  app/forge-demo/components/run-summary.tsx \
  app/forge-demo/page.tsx

echo "✓ Product-facing run summary projection"
echo "✓ Demo scenario contracts"
echo "✓ Named full-lifecycle demo scenario"
echo "✓ Named cognitive-output demo scenario"
echo "✓ Full lifecycle demo path"
echo "✓ Input → Execution → Reflection → Recommendation → Authorization → Action"
echo "✓ Inspectors preserved as proof layer"
echo "✓ No demo-faked kernel artifacts"
echo "✓ No action execution"
echo "✓ No implicit kernel mutation"

print_section "Reflection"
print_existing \
  lib/kernel/reflection/types.ts \
  lib/kernel/reflection/reflection-engine.ts \
  lib/kernel/reflection/basic-reflection-engine.ts \
  lib/kernel/reflection/reflection-repository.ts \
  lib/kernel/reflection/in-memory-reflection-repository.ts \
  lib/kernel/reflection/index.ts

echo "✓ Execution-derived reflection"
echo "✓ Meaningful cognitive output reflection"
echo "✓ Empty reasoning detected as artifact quality warning"
echo "✓ ReflectionRepository"
echo "✓ ReflectionEngine"
echo "✓ Reflection records projected into demo"

print_section "Recommendation"
print_existing \
  lib/kernel/recommendation/types.ts \
  lib/kernel/recommendation/recommendation-engine.ts \
  lib/kernel/recommendation/basic-recommendation-engine.ts \
  lib/kernel/recommendation/recommendation-repository.ts \
  lib/kernel/recommendation/in-memory-recommendation-repository.ts \
  lib/kernel/recommendation/index.ts

echo "✓ Reflection-derived recommendations"
echo "✓ RecommendationRepository"
echo "✓ RecommendationEngine"
echo "✓ Recommendation records projected into demo"
echo "✓ No automatic action execution"

print_section "Authorization"
print_existing \
  lib/kernel/authorization/types.ts \
  lib/kernel/authorization/authorization-engine.ts \
  lib/kernel/authorization/basic-authorization-engine.ts \
  lib/kernel/authorization/authorization-repository.ts \
  lib/kernel/authorization/in-memory-authorization-repository.ts \
  lib/kernel/authorization/index.ts \
  lib/demo/authorization/types.ts \
  lib/demo/authorization/authorization-decision-inspector-builder.ts \
  lib/demo/authorization/index.ts \
  app/forge-demo/components/authorization-decision-inspector.tsx

echo "✓ Recommendation-derived authorization decisions"
echo "✓ AuthorizationRepository"
echo "✓ AuthorizationEngine"
echo "✓ Deterministic policy evaluation"
echo "✓ Authorization decisions projected into demo"
echo "✓ No action execution"
echo "✓ No implicit kernel mutation"

print_section "Action"
print_existing \
  lib/kernel/action/types.ts \
  lib/kernel/action/action-repository.ts \
  lib/kernel/action/in-memory-action-repository.ts \
  lib/kernel/action/action-materialization-engine.ts \
  lib/kernel/action/basic-action-materialization-engine.ts \
  lib/kernel/action/index.ts \
  lib/demo/action/types.ts \
  lib/demo/action/action-inspector-builder.ts \
  lib/demo/action/index.ts \
  app/forge-demo/components/action-inspector.tsx

echo "✓ Authorization-derived action materialization"
echo "✓ ActionRepository"
echo "✓ ActionMaterializationEngine"
echo "✓ Deterministic materialization rules"
echo "✓ Action records projected into demo"
echo "✓ Durable intended work only"
echo "✓ No action execution"
echo "✓ No implicit kernel mutation"

print_section "Repositories"
find lib/kernel -name "*repository.ts" -o -name "in-memory-*-repository.ts" | sort

print_section "Engines"
find lib/kernel -name "*engine.ts" | sort

print_section "World Model"
print_existing \
  lib/kernel/world-model/basic-world-model-builder.ts \
  lib/kernel/world-model/world-model-builder.ts \
  lib/kernel/world-model/reasoning-adapter.ts \
  lib/kernel/world-model/types.ts

print_section "Agency"
print_existing \
  lib/kernel/goal/goal-engine.ts \
  lib/kernel/goal/goal-repository.ts \
  lib/kernel/goal/basic-goal-engine.ts \
  lib/kernel/planning/planning-engine.ts \
  lib/kernel/planning/plan-repository.ts \
  lib/kernel/planning/basic-planning-engine.ts

print_section "Demo / Timeline"
print_existing \
  lib/demo/timeline/types.ts \
  lib/demo/timeline/execution-timeline-builder.ts \
  app/forge-demo/components/execution-timeline.tsx \
  app/forge-demo/components/pipeline-stage.tsx \
  app/forge-demo/page.tsx

print_section "Kernel Contexts"
find lib/kernel -mindepth 1 -maxdepth 1 -type d | sort

print_section "Demo Files"
find lib/demo app/forge-demo -maxdepth 4 -type f | sort

print_section "Package Scripts"
node -e "const p=require('./package.json'); for (const [k,v] of Object.entries(p.scripts ?? {})) console.log(k + ' = ' + v)"