  lib/kernel/cognitive-pipeline/execution/pass-execution.ts \
  lib/kernel/cognitive-pipeline/execution/pass-execution-recorder.ts \
  lib/kernel/execution/types.ts \
  lib/kernel/execution/execution-recorder.ts

echo "✓ PassExecutionRecorder"
echo "✓ CognitivePassExecution"
echo "✓ KernelExecution.passExecutions"
echo "✓ Per-pass artifact deltas"
echo "✓ Duration metrics"
echo "✓ Failure capture"

