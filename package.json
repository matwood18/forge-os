    "proof:import-session-resumable": "tsx scripts/proofs/import-session-resumable-proof.ts",
    "proof:import-checkpoint": "tsx scripts/proofs/import-checkpoint-proof.ts",
    "proof:import-provider-execution": "tsx scripts/proofs/import-provider-execution-proof.ts",
    "proof:durable-import-state": "tsx scripts/proofs/durable-import-state-proof.ts"
  },
  "dependencies": {
