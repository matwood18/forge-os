generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EntityType {
  PERSON
  ORGANIZATION
  PLACE
  PRODUCT
  PROJECT
  UNKNOWN
}

model Entity {
  id          String     @id @default(cuid())
  type        EntityType
  displayName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjectObservations Observation[] @relation("SubjectObservations")
  objectObservations  Observation[] @relation("ObjectObservations")

  @@index([type])
  @@index([displayName])
}

model Observation {
  id String @id @default(cuid())

  subjectEntityId String
  subjectEntity   Entity @relation("SubjectObservations", fields: [subjectEntityId], references: [id])

  predicate String

  objectEntityId String?
  objectEntity   Entity? @relation("ObjectObservations", fields: [objectEntityId], references: [id])

  objectValue String?
  confidence  Float

  sourceEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectEntityId])
  @@index([objectEntityId])
  @@index([predicate])
}

model ImportSession {
  id String @id

  sourceSystem String
  externalId   String

  status String

  discovered Int
  processed   Int
  succeeded   Int
  failed      Int

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceSystem, externalId])
  @@index([sourceSystem])
  @@index([externalId])
  @@index([status])
}

model ImportCheckpoint {
  id String @id

  sourceSystem     String
  externalImportId String

  cursorPayload String?
  completed     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceSystem, externalImportId])
  @@index([sourceSystem])
  @@index([externalImportId])
  @@index([completed])
}
