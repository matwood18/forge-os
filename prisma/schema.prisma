generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EntityType {
  PERSON
  ORGANIZATION
  PLACE
  PRODUCT
  PROJECT
  UNKNOWN
}

model Entity {
  id          String     @id @default(cuid())
  type        EntityType
  displayName String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([type])
  @@index([displayName])
}